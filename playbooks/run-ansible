# A single call to ansible-playbook that works for batesste-ansible. See
# README.md for more information.

PLAYBOOK=${PLAYBOOK:-setup.yml}
HOSTS=${HOSTS:-hosts.yml}
FIRST_TIME=${FIRST_TIME:-false}
TARGETS=${TARGETS:-localvms}
RECIPE=${RECIPE:-newmachine}
TAGS=${TAGS:-}

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd -- "${SCRIPT_DIR}/.." && pwd)
ANSIBLE_ROLES_PATH=${ANSIBLE_ROLES_PATH:-"${REPO_ROOT}/roles"}
export ANSIBLE_ROLES_PATH

if [ ! -f "${HOSTS}" ]; then
    echo "${HOSTS} does not exist. Exiting!"
    exit -1
fi

AP_EXTRA=()
AP_VARS=()

if [ -n "${TAGS}" ]; then
    AP_EXTRA+=(--tags "${TAGS}")
fi

if [ "$(basename -- "${PLAYBOOK}")" != "setup-ec2.yml" ]; then
    AP_VARS+=(--extra-vars "targets=${TARGETS}")
    AP_VARS+=(--extra-vars "setup_recipe=${RECIPE}")
fi

if [ "${FIRST_TIME}" = "true" ]; then
    AP_VARS+=(--extra-vars "setup_roles=user_setup")
    AP_VARS+=(--extra-vars "ansible_user=ubuntu")
fi

if [ -f vault-password ]; then
    AP_EXTRA+=(--vault-password-file vault-password)
elif [ "${RUN_ANSIBLE_NO_VAULT:-}" != "1" ]; then
    printf '%s\n' \
        "vault-password does not exist. Exiting!" \
        "Set RUN_ANSIBLE_NO_VAULT=1 to run without a vault file."
    exit -1
fi

if [ "${FIRST_TIME}" = "true" ]; then
    AP_EXTRA+=(--ask-pass --ask-become-pass)
elif [ -f sudo-password ]; then
    AP_EXTRA+=(--become-password-file sudo-password)
elif [ "${RUN_ANSIBLE_NO_SUDO_PASS:-}" != "1" ]; then
    printf '%s\n' \
        "sudo-password does not exist. Exiting!" \
        "Set RUN_ANSIBLE_NO_SUDO_PASS=1 to run without a become password file."
    exit -1
fi

ansible-playbook "${PLAYBOOK}" \
  -i "${HOSTS}" \
  "${AP_EXTRA[@]}" \
  "${AP_VARS[@]}" "$@"
