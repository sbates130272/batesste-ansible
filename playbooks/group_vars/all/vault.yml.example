---
# Copy to vault.yml and encrypt with ansible-vault before use:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt playbooks/group_vars/all/vault.yml
#
# IAM credentials used only on the control node (localhost play) to call the EC2 API.
# You may use the same principal as cloud_setup or a narrower EC2-only user.

vault_aws_ec2_access_key_id: AKIAREPLACEWITHYOURACCESSKEY
vault_aws_ec2_secret_access_key: REPLACEWITHYOURSECRETACCESSKEY
