---
# .ansible-lint
# See https://ansible-lint.readthedocs.io/configuring/

exclude_paths:
  - .github
  - playbooks

warn_list:
  - command-instead-of-module
  - command-instead-of-shell
  - name[template]
  - schema[meta]  # Ubuntu resolute not yet in schema
  - var-naming[no-role-prefix]

extra_vars:
  targets: localhost
